#!/data/data/com.termux/files/usr/bin/bash
# ============================================================
#  hacklab-v2 / bin/hacklab
#
#  Single entrypoint, same command either side of the no-root /
#  root split:
#    - plain Termux session            -> no-root sandbox context
#    - SSH'd in over dropbear (:8022)  -> you're inside the
#                                          root-mode Alpine chroot
#
#  Both are interactive shells, so both get the interactive menu —
#  only HACKLAB_HOME and which capabilities are available differ.
#  Detection is by filesystem fact (alpine-release + the chroot's
#  known install path), not by guessing from env vars.
# ============================================================
set -e

detect_context() {
    if [ -f /etc/alpine-release ] && [ -d /opt/hacklab ]; then
        echo "chroot"
    elif [ -d /data/data/com.termux/files/usr ]; then
        echo "termux"
    else
        echo "unknown"
    fi
}

CONTEXT="$(detect_context)"

case "$CONTEXT" in
    chroot) export HACKLAB_HOME="/opt/hacklab" ;;
    termux)  export HACKLAB_HOME="${HACKLAB_HOME:-$HOME/.hacklab}" ;;
    *)
        echo "hacklab: couldn't detect environment (not Termux, not the hacklab chroot)." >&2
        echo "  Set HACKLAB_HOME yourself and re-run if this is a custom setup." >&2
        exit 1
        ;;
esac

if [ ! -f "$HACKLAB_HOME/lib/common.sh" ]; then
    echo "hacklab: $HACKLAB_HOME doesn't look like an installed hacklab tree." >&2
    echo "  (no lib/common.sh found — run install.sh first)" >&2
    exit 1
fi
source "$HACKLAB_HOME/lib/common.sh"

banner() {
    # Two-tier only (gum / plain) — same reasoning as style_ok() in
    # core/menu.sh: dialog has no "print styled text and keep
    # scrolling" widget, only modal boxes drawn at a screen-relative
    # position. A banner that's meant to sit above choose()'s menu
    # every loop iteration would either block on a keypress it
    # doesn't need, or get wiped the moment the next box draws —
    # neither is an improvement over the plain log() line below.
    if verify_cmd gum --version; then
        gum style --border normal --margin "0 1" --padding "0 1" \
            --border-foreground 212 --foreground 212 "hacklab — $1"
    else
        log "hacklab — $1"
    fi
}

choose() {
    # $1 = header, rest = options. Echoes the picked line, empty if cancelled.
    # Guarded with `|| true`: gum/dialog/select all exit non-zero on
    # cancel (Esc, Ctrl-C, "back" in dialog's box), and this runs
    # under `set -e` — without the guard, backing out of any menu
    # would kill hacklab outright instead of returning to the caller
    # with an empty pick.
    local header="$1"; shift
    if verify_cmd gum --version; then
        printf '%s\n' "$@" | gum choose --header "$header" || true
    elif [ "${DIALOG_OK:-0}" = "1" ]; then
        dialog_menu "$header" "$@" || true
    else
        local PS3="$header "
        select opt in "$@"; do echo "$opt"; break; done || true
    fi
}

root_chroot_reachable() {
    # From Termux: is the root-mode chroot's dropbear actually up?
    command -v nc >/dev/null 2>&1 && nc -z -w1 127.0.0.1 8022 2>/dev/null
}

service_control_submenu() {
    local svc_list svc
    svc_list="$(bash "$HACKLAB_HOME/lib/svc-engine.sh" status | tail -n +2 | awk '{print $1}')"
    [ -z "$svc_list" ] && { warn "no services found"; return; }
    svc="$(choose "service:" $svc_list)"
    [ -z "$svc" ] && return
    local action
    action="$(choose "action for $svc:" "start" "stop" "restart" "logs" "back")"
    case "$action" in
        start)   bash "$HACKLAB_HOME/lib/svc-engine.sh" start "$svc" ;;
        stop)    bash "$HACKLAB_HOME/lib/svc-engine.sh" stop "$svc" ;;
        restart) bash "$HACKLAB_HOME/lib/svc-engine.sh" restart "$svc" ;;
        logs)    bash "$HACKLAB_HOME/lib/svc-engine.sh" logs "$svc" ;;
        *) return ;;
    esac
}

main_menu_termux() {
    ensure_gum || true
    ensure_dialog || true
    while true; do
        banner "termux (no-root sandbox)"
        local opts=("dashboard (status / logs / shell)" "tool modules (install / run)" "service control" "web dashboard URL")
        root_chroot_reachable && opts+=("SSH into root-mode chroot")
        opts+=("quit")

        local pick
        pick="$(choose "what do you want to do?" "${opts[@]}")"
        [ -z "$pick" ] && exit 0

        case "$pick" in
            "dashboard"*)        bash "$HACKLAB_HOME/core/dashboard-tui.sh" ;;
            "tool modules"*)     bash "$HACKLAB_HOME/core/menu.sh" ;;
            "service control")  service_control_submenu ;;
            "web dashboard URL") ok "http://127.0.0.1:8080  — open in any browser on this device"; sleep 2 ;;
            "SSH into root-mode chroot") exec ssh -p 8022 root@127.0.0.1 ;;
            "quit") exit 0 ;;
        esac
    done
}

main_chroot() {
    banner "root-mode chroot (you're in over SSH)"
    log "Headless boot already brought the service graph up — this is just the interactive layer on top."
    if command -v tmux >/dev/null 2>&1 && verify_cmd gum --version; then
        bash "$HACKLAB_HOME/core/dashboard-tui.sh"
    else
        warn "tmux/gum aren't installed in this chroot by default — apk's package set diverges from Termux's."
        log "Plain status instead, then dropping you into a shell:"
        bash "$HACKLAB_HOME/lib/svc-engine.sh" status
        exec bash
    fi
}

case "$CONTEXT" in
    termux) main_menu_termux ;;
    chroot) main_chroot ;;
esac
